# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# HubSpot app credentials
# Find these in your HubSpot developer account under your app's Auth settings
# ---------------------------------------------------------------------------

# Client secret — used to verify incoming webhook signatures
HUBSPOT_CLIENT_SECRET=

# Client ID — used in the OAuth token exchange (/oauth-callback)
HUBSPOT_CLIENT_ID=

# Access token for deal enrichment (name + amount lookups via CRM API)
# Option A: Create a private app token in HubSpot (Settings → Integrations → Private Apps)
#           with scope crm.objects.deals.read, then paste the token here.
# Option B: Leave blank — the token returned by /oauth-callback will be logged
#           to the server console so you can copy it in.
HUBSPOT_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Integrations
# ---------------------------------------------------------------------------

# Slack incoming webhook URL — post a message when a deal closes
# Create one at https://api.slack.com/messaging/webhooks
# Leave blank to disable Slack notifications
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Deal stage config
# ---------------------------------------------------------------------------

# The HubSpot deal stage internal value for "Closed Won" in your portal
# Find it: Settings → Objects → Deals → Deal Stages → copy the internal value
CLOSED_WON_STAGE_ID=closedwon

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the server listens on (Railway sets this automatically)
PORT=3000
